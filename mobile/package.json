{
  "name": "mobile",
  "version": "1.0.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "./node_modules/.bin/expo start",
    "start:clear": "./node_modules/.bin/expo start --clear",
    "start:ios": "./node_modules/.bin/expo start --ios",
    "start:android": "./node_modules/.bin/expo start --android",
    "android": "./node_modules/.bin/expo run:android",
    "ios": "./node_modules/.bin/expo run:ios",
    "web": "./node_modules/.bin/expo start --web",
    "build:preview": "npx eas-cli build --profile preview --platform all",
    "build:preview:ios": "npx eas-cli build --profile preview --platform ios",
    "build:preview:android": "npx eas-cli build --profile preview --platform android",
    "build:production": "npx eas-cli build --profile production --platform all",
    "build:production:ios": "npx eas-cli build --profile production --platform ios",
    "build:production:android": "npx eas-cli build --profile production --platform android",
    "build:ios:latest": "npx eas-cli@latest build --platform ios --profile production",
    "submit:ios": "npx eas-cli submit --platform ios --latest",
    "submit:android": "npx eas-cli submit --platform android --latest",
    "prebuild:ios": "npx expo prebuild --platform ios --clean"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "^2.2.0",
    "@react-native-community/datetimepicker": "^9.1.0",
    "@supabase/supabase-js": "^2.98.0",
    "date-fns": "^4.1.0",
    "expo": "~56.0.9",
    "expo-constants": "~56.0.15",
    "expo-device": "~56.0.4",
    "expo-linking": "~56.0.13",
    "expo-network": "~56.0.5",
    "expo-notifications": "~56.0.16",
    "expo-router": "~56.2.9",
    "expo-status-bar": "~56.0.4",
    "expo-updates": "~56.0.18",
    "lodash": "^4.17.23",
    "react": "^19.2.3",
    "react-native": "^0.85.3",
    "react-native-chart-kit": "^6.12.0",
    "react-native-gesture-handler": "~2.31.1",
    "react-native-reanimated": "~4.3.1",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "^15.15.4",
    "react-native-worklets": "^0.8.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.14",
    "expo-build-properties": "~56.0.17",
    "typescript": "~6.0.3"
  },
  "private": true
}

{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "remote"
  },
  "build": {
    "preview": {
      "node": "20.19.4",
      "env": { "NPM_CONFIG_LEGACY_PEER_DEPS": "true" },
      "distribution": "internal",
      "ios": { "simulator": false },
      "android": { "buildType": "apk" },
      "channel": "preview"
    },
    "production": {
      "node": "20.19.4",
      "env": { "NPM_CONFIG_LEGACY_PEER_DEPS": "true" },
      "distribution": "store",
      "channel": "production",
      "autoIncrement": true
    }
  },
  "submit": {
    "preview": {
      "ios": {
        "ascAppId": "6760584228",
        "appleId": "robin.lacroix@gmail.com"
      }
    },
    "production": {
      "ios": {
        "ascAppId": "6760584228",
        "appleId": "robin.lacroix@gmail.com"
      },
      "android": { "track": "internal" }
    }
  }
}
